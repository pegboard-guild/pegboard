# Pegboard Environment Configuration
# Copy to .env and fill in your values

# === Frontend (React) ===

# Supabase Configuration
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# Optional: Google Civic API for district lookup
GOOGLE_CIVIC_API_KEY=your-google-api-key

# === Graph Layer (Python) ===

# Congress.gov API (free: https://api.congress.gov/sign-up/)
# DEMO_KEY works but has stricter rate limits
CONGRESS_API_KEY=DEMO_KEY

# FEC API (free: https://api.open.fec.gov/developers/)
FEC_API_KEY=DEMO_KEY

# Neo4j (only needed for graph loading, not for ingestor development)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=pegboard

# API
API_HOST=0.0.0.0
API_PORT=8000

# Environment
NODE_ENV=development
