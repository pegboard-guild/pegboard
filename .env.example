# Pegboard Environment Variables
# Copy this file to .env and fill in your API keys.

# ── Congress.gov API ──────────────────────────────────────────────
# Free key: https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# ── FEC (Federal Election Commission) API ────────────────────────
# Free key: https://api.open.fec.gov/developers/
FEC_API_KEY=

# ── OpenStates API ────────────────────────────────────────────────
# Free key: https://openstates.org/accounts/signup/
OPENSTATES_API_KEY=

# ── Google Civic Information API ──────────────────────────────────
# Free via Google Cloud Console: https://console.cloud.google.com/apis/library/civicinfo.googleapis.com
GOOGLE_CIVIC_API_KEY=

# ── Neo4j (graph database layer) ─────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=pegboard

# ── Supabase (optional — only needed if using Supabase backend) ──
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# ── USAspending API ───────────────────────────────────────────────
# No API key required — public endpoint at https://api.usaspending.gov
