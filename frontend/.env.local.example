# Pegboard Frontend Environment Variables
# Copy this file to .env.local and fill in your API keys.

# Congress.gov API key (free: https://api.congress.gov/sign-up/)
REACT_APP_CONGRESS_API_KEY=

# Google Civic Information API key (free via GCP: https://console.cloud.google.com/apis/library/civicinfo.googleapis.com)
REACT_APP_GOOGLE_CIVIC_API_KEY=

# OpenStates API key (free: https://openstates.org/accounts/signup/)
REACT_APP_OPENSTATES_API_KEY=

# Supabase (optional — only if using Supabase backend)
# REACT_APP_SUPABASE_URL=
# REACT_APP_SUPABASE_ANON_KEY=
