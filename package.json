{
  "name": "pegboard",
  "version": "1.0.0",
  "description": "Radical transparency for government - track every action, vote, and decision",
  "private": true,
  "scripts": {
    "dev": "cd frontend && npm start",
    "build": "cd frontend && npm run build",
    "install:all": "npm install && cd frontend && npm install",
    "deploy:functions": "supabase functions deploy --all",
    "db:migrate": "supabase db push",
    "db:seed": "supabase db seed",
    "test": "cd frontend && npm test",
    "lint": "cd frontend && npm run lint"
  },
  "keywords": [
    "civic-tech",
    "government",
    "transparency",
    "democracy",
    "congress",
    "voting",
    "politics"
  ],
  "author": "Pegboard Team",
  "license": "MIT",
  "devDependencies": {
    "supabase": "^1.142.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "js-yaml": "^4.1.0",
    "node-fetch": "^2.7.0"
  }
}
